# Copy this file to hermes.config.env, then fill in values.
# Lines starting with # are ignored.

# Docker images.
# Use Docker Hub when it is available:
HERMES_IMAGE=nousresearch/hermes-agent:latest
# If Docker Hub is slow in China, use a reachable mirror image instead:
# HERMES_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/nousresearch/hermes-agent:latest
HERMES_REDIS_IMAGE=redis:7-alpine

# Docker names.
HERMES_CONTAINER_NAME=hermes
HERMES_REDIS_CONTAINER_NAME=hermes-redis
HERMES_NETWORK_NAME=hermesagent_hermes-net
HERMES_DATA_VOLUME=hermesagent_hermes_data
HERMES_REDIS_VOLUME=hermesagent_redis_data

# Host ports.
HERMES_GATEWAY_PORT=8642
HERMES_DASHBOARD_PORT=9119

# Hermes command. Keep this as two words separated by one space.
HERMES_GATEWAY_ARGS=gateway run

# Set true when the image already exists locally and pulling is slow.
HERMES_SKIP_PULL=false

# Hermes runtime.
HERMES_DASHBOARD=1
# For local testing only. For production, configure platform allowlists instead.
GATEWAY_ALLOW_ALL_USERS=false

# Model/API keys. Fill at least one provider or run: docker exec -it hermes hermes model
HERMES_MODEL=anthropic/claude-opus-4.6
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ZAI_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=

# Messaging platforms. Fill only the platforms you use.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_ALLOWED_USERS=

# Optional tools.
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
BROWSERBASE_API_KEY=
FAL_KEY=
