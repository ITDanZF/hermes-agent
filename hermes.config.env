# Hermes 部署配置文件
# 填写完成后，在 PowerShell 中运行：
#   .\deploy-hermes.ps1 recreate
#
# 注意：
# - 等号左侧是配置名，不要修改。
# - 等号右侧填写你的值。
# - 不使用的配置可以留空。
# - 如果值里有空格，建议用英文双引号包起来。

# -----------------------------
# 1. Docker 镜像配置
# -----------------------------

# Hermes 镜像。
# 如果 Docker Hub 可用，可以改成：
# HERMES_IMAGE=nousresearch/hermes-agent:latest
# 如果 Docker Hub 拉取慢，可以使用当前本机已验证可用的国内镜像：
HERMES_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/nousresearch/hermes-agent:latest

# Redis 镜像，一般不用改。
HERMES_REDIS_IMAGE=redis:7-alpine

# 本机已经有镜像时设置为 true，脚本会跳过 docker pull，避免卡在拉取镜像。
# 如果你希望每次部署前都拉取最新镜像，改成 false。
HERMES_SKIP_PULL=true

# -----------------------------
# 2. Docker 容器、网络、数据卷
# -----------------------------

# Hermes 容器名称。线上 Nginx 会通过 http://hermes-agent:8642 访问它。
HERMES_CONTAINER_NAME=hermes-agent

# Redis 容器名称。
HERMES_REDIS_CONTAINER_NAME=hermes-redis

# Hermes 和 Redis 共用的 Docker 网络。
# 线上部署时请改成现有 Nginx 容器所在的 Docker network 名称。
HERMES_NETWORK_NAME=hermesagent_hermes-net

# Hermes 数据卷。这里保存 Hermes 配置、状态、日志、会话等数据。
HERMES_DATA_VOLUME=hermesagent_hermes_data

# Redis 数据卷。
HERMES_REDIS_VOLUME=hermesagent_redis_data

# -----------------------------
# 3. 端口配置
# -----------------------------

# Gateway 对外端口，默认访问：http://localhost:8642
HERMES_GATEWAY_PORT=8642

# Dashboard 对外端口，默认访问：http://localhost:9119
HERMES_DASHBOARD_PORT=9119

# 是否把 Hermes 的 8642/9119 端口映射到宿主机。
# 统一走线上 Nginx 时建议为 false，让 Hermes 只在 Docker 内部网络可访问。
HERMES_EXPOSE_HOST_PORTS=false

# Hermes 容器启动命令。保持 gateway run 即可，不建议修改。
HERMES_GATEWAY_ARGS=gateway run

# 是否启用 Dashboard。1 表示启用。
HERMES_DASHBOARD=1

# -----------------------------
# 4. 用户访问控制
# -----------------------------

# 本地测试可以设置为 true，允许所有用户访问 Gateway。
# 正式使用建议保持 false，并填写具体平台的允许用户 ID。
GATEWAY_ALLOW_ALL_USERS=false

# -----------------------------
# 5. 模型和 API Key
# -----------------------------

# 默认模型。你也可以通过 docker exec -it hermes-agent hermes model 交互式配置。
HERMES_MODEL=anthropic/claude-opus-4.6

# 至少填写一个可用的模型服务 API Key。
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ZAI_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=

# -----------------------------
# 6. 消息平台配置
# -----------------------------

# Telegram 配置。
# TELEGRAM_BOT_TOKEN 填 BotFather 创建的 Bot Token。
# TELEGRAM_ALLOWED_USERS 填允许访问的 Telegram 用户 ID，多个用户可按 Hermes 文档要求分隔。
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# Discord 配置。
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=

# Slack 配置。
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_ALLOWED_USERS=

# -----------------------------
# 7. 可选工具 API Key
# -----------------------------

# 搜索、浏览器、图片/多媒体等工具用到的可选 Key，不需要可留空。
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
BROWSERBASE_API_KEY=
FAL_KEY=
